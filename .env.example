# ── GCP Vertex AI 환경 (Gemini CLI / Cloud Shell / Cloud Run) ──────────────
# gcloud auth application-default login 실행 후 아래 두 줄만 설정
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── 로컬 개발 (Google AI Studio API 키) ──────────────────────────────────────
# GOOGLE_CLOUD_PROJECT가 없을 때만 사용됨
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_api_key_here

# ── 외부 서비스 API 키 (동영상 생성) ──────────────────────────────────────────
# GCP 비디오 생성을 대체하여 무료(초기 크레딧)로 동의상 클립 생성 시 사용 (fal.ai)
# FAL_KEY=your_fal_key_here
